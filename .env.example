# App
PORT=3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_db_password
DB_NAME=emart
DB_SYNC=false

# E2E Test Database (NEVER point these at production/dev DBs)
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_USER=postgres
TEST_DB_PASS=your_db_password
TEST_DB_NAME=emart_test

# JWT
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=1d
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email verification
EMAIL_VERIFICATION_SECRET=your-email-verification-secret

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email
MAIL_PASS=your-app-password
MAIL_FROM=your-email



# Payments
STRIPE_SECRET_KEY=your_stripe_secret_key
KASHIER_URL=https://sandbox.kashier.io
KASHIER_API_KEY=your_kashier_api_key
KASHIER_SECRET_KEY=your_kashier_secret_key
KASHIER_MERCHANT_ID=your_kashier_merchant_id
KASHIER_WEBHOOK_URL=https://your-public-domain.com/payments/webhook
KASHIER_WEBHOOK_SECRET=your_kashier_webhook_secret
KASHIER_REDIRECT_URL=https://your-public-frontend.com/checkout/confirmation
