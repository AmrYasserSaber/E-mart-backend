<html lang='en'>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <meta name='x-apple-disable-message-reformatting' />
    <title>Your E-mart partner request was not approved</title>
  </head>
  <body
    style='
      margin: 0;
      padding: 0;
      background-color: #fdf9f3;
      color: #584238;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto,
        Helvetica, Arial, sans-serif;
    '
  >
    <table
      role='presentation'
      cellpadding='0'
      cellspacing='0'
      border='0'
      width='100%'
      style='background-color: #fdf9f3'
    >
      <tr>
        <td align='center' style='padding: 32px 16px'>
          <table
            role='presentation'
            cellpadding='0'
            cellspacing='0'
            border='0'
            width='600'
            style='
              width: 100%;
              max-width: 600px;
              background-color: #ffffff;
              border-radius: 24px;
              box-shadow: 0px 4px 20px rgba(139, 114, 102, 0.08),
                0px 12px 40px rgba(139, 114, 102, 0.04);
              overflow: hidden;
            '
          >
            <tr>
              <td
                style='
                  padding: 22px 24px;
                  background-image: linear-gradient(135deg, #9b3f00 0%, #c25100 100%);
                  color: #ffffff;
                '
              >
                <div
                  style='
                    font-weight: 800;
                    letter-spacing: 0.02em;
                    font-size: 18px;
                    line-height: 1.2;
                    color: #ffffff;
                  '
                >
                  E-mart
                </div>
                <div
                  style='
                    margin-top: 6px;
                    font-weight: 600;
                    font-size: 14px;
                    line-height: 1.4;
                    color: #ffffff;
                    opacity: 0.92;
                  '
                >
                  Partner request update
                </div>
              </td>
            </tr>
            <tr>
              <td style='padding: 24px'>
                <div
                  style='
                    font-size: 16px;
                    line-height: 1.6;
                    color: #1c1c18;
                    font-weight: 700;
                    margin: 0;
                  '
                >
                  Hello
                  {{firstName}}
                  {{lastName}},
                </div>
                <div
                  style='
                    margin-top: 10px;
                    font-size: 15px;
                    line-height: 1.7;
                    color: #584238;
                  '
                >
                  Thank you for applying as an E-mart partner for
                  <strong>{{storeName}}</strong>.
                </div>
                <table
                  role='presentation'
                  cellpadding='0'
                  cellspacing='0'
                  border='0'
                  width='100%'
                  style='margin-top: 18px'
                >
                  <tr>
                    <td
                      align='left'
                      style='
                        padding: 16px;
                        background-color: #ebe8e2;
                        border-radius: 16px;
                        box-shadow: inset 4px 4px 8px rgba(139, 114, 102, 0.1),
                          inset -4px -4px 8px rgba(255, 255, 255, 0.9);
                        color: #584238;
                        font-size: 14px;
                        line-height: 1.6;
                      '
                    >
                      At this time, your partner request was not approved.
                    </td>
                  </tr>
                </table>
                <div
                  style='
                    margin-top: 18px;
                    padding: 14px 16px;
                    border-radius: 16px;
                    background-color: #ffdbcb;
                    color: #341000;
                    border: 1px solid rgba(155, 63, 0, 0.18);
                    font-size: 13px;
                    line-height: 1.6;
                  '
                >
                  You can still use your account as a customer and submit a new
                  partner request later.
                </div>
              </td>
            </tr>
            <tr>
              <td
                style='
                  padding: 18px 24px;
                  background-color: #dddad4;
                  color: #584238;
                  font-size: 12px;
                  line-height: 1.6;
                '
              >
                <div style='margin: 0'>
                  You’re receiving this because you applied for an E-mart
                  partner account.
                </div>
              </td>
            </tr>
          </table>
          <div
            style='
              max-width: 600px;
              margin-top: 12px;
              font-size: 11px;
              line-height: 1.6;
              color: #584238;
              opacity: 0.85;
            '
          >
            ©
            {{year}}
            E-mart
          </div>
        </td>
      </tr>
    </table>
  </body>
</html>